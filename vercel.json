{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "1.jpg", "use": "@vercel/static" }
  ],
  "routes": [
    { 
      "src": "/api/(.*)", 
      "dest": "/server.js" 
    },
    { 
      "src": "/1.jpg", 
      "dest": "/1.jpg" 
    },
    { 
      "src": "/style.css", 
      "dest": "/style.css" 
    },
    { 
      "src": "/script.js", 
      "dest": "/script.js" 
    },
    { 
      "src": "/(.*)", 
      "dest": "/index.html" 
    }
  ]
}
